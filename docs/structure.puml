@startuml Leonardo - class structure

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor      #555577
    ArrowColor       #444466
    FontName         Monospaced
}
skinparam package {
    BackgroundColor  #F4F4FF
    BorderColor      #7777AA
    FontStyle        Bold
}
skinparam interface {
    BackgroundColor  #FFFBE6
    BorderColor      #AAAA55
}

hide empty members

' ===================================================
' PACKAGE: core
' Foundation shared by every domain.
' ===================================================
package "core" {

    interface "_Expression" <<trait>> {
        + eval(env: Environment): Either
        + children: List
        + rebuild(cs: List): _Expression
        + freeVars: Set
    }

    interface "_Value" <<trait>>

    class "_Number" <<case>> {
        + d: Double
        + display(precision: Int): String
    }

    class "_Variable" <<case>> {
        + variable: String
    }

    class "_MatrixValue" <<case>> {
        + rows: Int
        + cols: Int
        + data: Array[Double]
        + add(that): _MatrixValue
        + multiply(that): _MatrixValue
        + transpose: _MatrixValue
        + scale(k: Double): _MatrixValue
    }

    class "Environment" {
        + precision: Int
        + get(name: String): Option
        + withBinding(name, v): Environment
        __ companion __
        DefaultPrecision: Int = 5
    }

    "_Value"       --|> "_Expression"
    "_Number"      ..|> "_Value"
    "_MatrixValue" ..|> "_Value"
    "_Variable"    ..|> "_Expression"
    "_Expression"  --> "Environment" : eval(env)
}

' ===================================================
' PACKAGE: scalar - AST nodes
' ===================================================
package "scalar" {

    ' -- Operations ---------------------------------
    interface "_Operation" <<trait>>

    class "Sum" <<case>> {
        a : _Expression
        b : _Expression
    }
    class "Product" <<case>> {
        a : _Expression
        b : _Expression
    }
    class "Ratio" <<case>> {
        a : _Expression
        b : _Expression
    }
    class "Power" <<case>> {
        base : _Expression
        exp  : _Expression
    }

    "_Operation" --|> "_Expression"
    "Sum"        --|> "_Operation"
    "Product"    --|> "_Operation"
    "Ratio"      --|> "_Operation"
    "Power"      --|> "_Operation"

    ' -- Unary Functions ----------------------------
    abstract class "_Function"

    class "Exp" <<case>> {
        e : _Expression
    }
    class "Log" <<case>> {
        e : _Expression
    }
    class "Sin" <<case>> {
        e : _Expression
    }
    class "Cos" <<case>> {
        e : _Expression
    }
    class "Tg" <<case>> {
        e : _Expression
    }
    class "Asin" <<case>> {
        e : _Expression
    }
    class "Acos" <<case>> {
        e : _Expression
    }
    class "Atan" <<case>> {
        e : _Expression
    }

    "_Function" --|> "_Expression"
    "Exp"  --|> "_Function"
    "Log"  --|> "_Function"
    "Sin"  --|> "_Function"
    "Cos"  --|> "_Function"
    "Tg"   --|> "_Function"
    "Asin" --|> "_Function"
    "Acos" --|> "_Function"
    "Atan" --|> "_Function"

    ' -- Functionals (higher-order) -----------------
    abstract class "_Functional"

    class "_Derivative" <<case>> {
        e : _Expression
        v : _Variable
    }
    class "_Integral" <<case>> {
        e : _Expression
        v : _Variable
    }
    class "_DefIntegral" <<case>> {
        e         : _Expression
        v         : _Variable
        low_limit : _Expression
        up_limit  : _Expression
    }

    "_Functional"  --|> "_Expression"
    "_Derivative"  --|> "_Functional"
    "_Integral"    --|> "_Functional"
    "_DefIntegral" --|> "_Functional"

    ' -- Algorithm modules (package-level functions) -
    class "Derive" <<utility>> {
        + derive(e, v): _Expression
    }
    class "Integrate" <<utility>> {
        + integrate(e, v): _Expression
    }
    class "Simplify" <<utility>> {
        + simplify(e): _Expression
        + simplifyFully(e): _Expression
    }
    class "Expand" <<utility>> {
        + expand(e): _Expression
    }
    class "Substitute" <<utility>> {
        + substitute(e, defs): _Expression
    }
    class "Analysis" <<utility>> {
        + dependsOn(e, v): Boolean
    }
    class "Compile" <<utility>> {
        + compile(e, v, env): Option
    }

    class "Syntax" <<object>> {
        simplify() / simplifyFully()
        expand()
        derive(v) / integrate(v)
        dependsOn(v) / substitute(defs)
        compile(v)
    }

    ' Functional nodes call algorithm modules at eval time
    "_Derivative"  ..> "Derive"    : derive() at eval
    "_Integral"    ..> "Integrate" : integrate() at eval
    "_DefIntegral" ..> "Compile"   : compile() fast path

    ' Syntax sugar delegates to each algorithm module
    "Syntax" ..> "Derive"     : delegates
    "Syntax" ..> "Integrate"  : delegates
    "Syntax" ..> "Simplify"   : delegates
    "Syntax" ..> "Expand"     : delegates
    "Syntax" ..> "Substitute" : delegates
    "Syntax" ..> "Analysis"   : delegates
    "Syntax" ..> "Compile"    : delegates
}

' ===================================================
' PACKAGE: matrix - matrix domain (imports core + scalar)
' ===================================================
package "matrix" {

    class "_Matrix" <<case>> {
        + rows: Int
        + cols: Int
        + elems: Vector[_Expression]
        __ companion __
        + ofRows(rows*): _Matrix
        + fromValue(v): _Matrix
    }

    interface "_MatrixOperation" <<trait>>

    class "MatSum" <<case>> {
        a : _Expression
        b : _Expression
    }
    class "MatProduct" <<case>> {
        a : _Expression
        b : _Expression
    }
    class "MatScale" <<case>> {
        k : _Expression
        m : _Expression
    }
    class "Transpose" <<case>> {
        m : _Expression
    }

    "_Matrix"          --|> "_Expression"
    "_MatrixOperation" --|> "_Expression"
    "MatSum"           --|> "_MatrixOperation"
    "MatProduct"       --|> "_MatrixOperation"
    "MatScale"         --|> "_MatrixOperation"
    "Transpose"        --|> "_MatrixOperation"

    "_Matrix"          ..> "_MatrixValue" : collapses to at eval
    "_MatrixOperation" ..> "_MatrixValue" : dense kernels (fast path)
    "_MatrixOperation" ..> "Sum"          : element-wise symbolic combine
    "_MatrixOperation" ..> "Product"      : element-wise symbolic combine
}

' ===================================================
' PACKAGE: parser
' ===================================================
package "parser" {
    class "Parser" <<object>> {
        + parse(str: String): ParseResult
        __ __
        MaxDepth = 500
    }
}

"Parser" ..> "_Expression" : produces AST nodes

' ===================================================
' PACKAGE: cli   (leaf - nothing imports it)
' ===================================================
package "cli" {
    class "Session" {
        - precision: Int
        - bindings: Map
        - definitions: Map
        + execute(line: String): String
        + script: String
        + load(text: String): String
        __ companion __
        ReservedConstants: Set = {pi, e}
        + loadFile(session, path): String
        + saveFile(session, path): String
    }

    class "repl()" <<main>> {
        reads StdIn in a loop
        dispatches :load / :save
    }

    "repl()" --> "Session" : creates and drives
}

"Session" --> "Parser"      : parses every input line
"Session" --> "Environment" : builds per command
"Session" ..> "Derive"      : derive command
"Session" ..> "Simplify"    : simplify command
"Session" ..> "Expand"      : expand command
"Session" ..> "Substitute"  : resolves definitions

@enduml
