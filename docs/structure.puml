@startuml

' Layout engine: Graphviz dot (default).
' If dot is not on PATH, set GRAPHVIZ_DOT before running `sbt puml`
' or add `!pragma layout smetana` here to use the built-in pure-Java engine
' (smetana does NOT support clickable [[url]] links in SVG).

!define DIAGRAM_WIDTH 12000
!define DIAGRAM_HEIGHT 8000
skinparam defaultFontName Courier
skinparam monochrome true

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor      #555577
    ArrowColor       #444466
    FontName         Monospaced
}
skinparam package {
    BackgroundColor  #F4F4FF
    BorderColor      #7777AA
    FontStyle        Bold
}
skinparam interface {
    BackgroundColor  #FFFBE6
    BorderColor      #AAAA55
}

hide empty members

' ===================================================
' PACKAGE: core
' Foundation shared by every domain.
' ===================================================
package "core" {

    interface "_Expression" <<trait>> [[expressions.html]] {
        + eval(env: Environment): Either
        + children: List
        + rebuild(cs: List): _Expression
        + freeVars: Set
    }

    interface "_Value" <<trait>> [[expressions.html]]

    interface "_ElementWise" <<trait>> [[expressions.html]]

    interface "_MatrixShaped" <<trait>> [[matrix.html]] {
        + rows: Int
        + cols: Int
    }

    class "_Number" <<case>> [[expressions.html]] {
        + d: Double
        + display(precision: Int): String
    }

    class "_Bool" <<case>> [[expressions.html]] {
        + b: Boolean
    }

    class "_Complex" <<case>> [[equations.html]] {
        + re: Double
        + im: Double
        + display(precision: Int): String
        __ companion __
        + of(re, im): _Value  (im==0 -> _Number)
        + add/sub/mul/div/pow
        + expc/logc/sinc/cosc/tanc
    }

    class "_Variable" <<case>> [[expressions.html]] {
        + variable: String
    }

    class "_MatrixValue" [[matrix.html]] {
        + rows: Int
        + cols: Int
        - data: Array[Double]
        + toVector: Vector[Double]
        + display(precision: Int): String
        + add(that): _MatrixValue
        + multiply(that): _MatrixValue
        + transpose: _MatrixValue
        + scale(k: Double): _MatrixValue
        + determinant: Option[Double]
        + inverse: Option[_MatrixValue]
        + luDecompose: Option[(L, U, P)]
        + qrDecompose: Option[(Q, R)]
        + eigenDecompose: Option[Vector[_Value]]
        + spectralDecompose: Option[(Vector[Vector[_Value]], Vector[_Value])]
        + kronecker(that): _MatrixValue
        + vec: _MatrixValue
        + guarded(orElse): Either
        __ companion __
        + apply(rows, cols, data) : defensive copy
        + identity(n): _MatrixValue
        + unvec(v, rows, cols): Option[_MatrixValue]
    }

    class "Environment" [[expressions.html]] {
        + precision: Int
        + get(name: String): Option
        + withBinding(name, v): Environment
        __ companion __
        DefaultPrecision: Int = 5
    }

    "_Value"        --|> "_Expression"
    "_ElementWise"  --|> "_Expression"
    "_MatrixShaped" --|> "_Expression"
    "_Number"      ..|> "_Value"
    "_Bool"        ..|> "_Value"
    "_Complex"     ..|> "_Value"
    "_MatrixValue" ..|> "_Value"
    "_Variable"    ..|> "_Expression"
    "_Expression"  --> "Environment" : eval(env)
}

' ===================================================
' PACKAGE: scalar - AST nodes
' ===================================================
package "scalar" {

    ' -- Operations ---------------------------------
    interface "_Operation" <<trait>> [[expressions.html]]

    class "Sum" <<case>> [[expressions.html]] {
        a : _Expression
        b : _Expression
    }
    class "Product" <<case>> [[expressions.html]] {
        a : _Expression
        b : _Expression
    }
    class "Ratio" <<case>> [[expressions.html]] {
        a : _Expression
        b : _Expression
    }
    class "Power" <<case>> [[expressions.html]] {
        base : _Expression
        exp  : _Expression
    }

    "_Operation" --|> "_Expression"
    "Sum"        --|> "_Operation"
    "Product"    --|> "_Operation"
    "Ratio"      --|> "_Operation"
    "Power"      --|> "_Operation"

    ' -- Unary Functions ----------------------------
    abstract class "_Function" [[expressions.html]] {
        __ element-wise over a matrix arg __
        mapMatrix(mv, f) : distributes f over dense elements
    }

    class "Exp" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Log" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Sin" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Cos" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Tg" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Asin" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Acos" <<case>> [[expressions.html]] {
        e : _Expression
    }
    class "Atan" <<case>> [[expressions.html]] {
        e : _Expression
    }

    "_Function" --|> "_Expression"
    "Exp"  --|> "_Function"
    "Log"  --|> "_Function"
    "Sin"  --|> "_Function"
    "Cos"  --|> "_Function"
    "Tg"   --|> "_Function"
    "Asin" --|> "_Function"
    "Acos" --|> "_Function"
    "Atan" --|> "_Function"

    ' -- Functionals (higher-order) -----------------
    abstract class "_Functional" [[calculus.html]]

    class "_Derivative" <<case>> [[calculus.html]] {
        e : _Expression
        v : _Variable
    }
    class "_Integral" <<case>> [[calculus.html]] {
        e : _Expression
        v : _Variable
    }
    class "_DefIntegral" <<case>> [[calculus.html]] {
        e         : _Expression
        v         : _Variable
        low_limit : _Expression
        up_limit  : _Expression
    }
    class "_Limit" <<case>> [[calculus.html]] {
        e     : _Expression
        v     : _Variable
        point : _Expression
        dir   : LimitDir
    }

    enum "LimitDir" [[calculus.html]] {
        Both
        FromRight
        FromLeft
    }

    "_Functional"  --|> "_Expression"
    "_Derivative"  --|> "_Functional"
    "_Integral"    --|> "_Functional"
    "_DefIntegral" --|> "_Functional"
    "_Limit"       --|> "_Functional"

    ' -- Algorithm modules (package-level functions) -
    class "Limit" <<utility>> [[calculus.html]] {
        + evalLimit(e, v, point, dir, env): _Expression
        __ tiers __
        1. direct substitution
        2. L'Hopital (0/0, inf/inf, c/0)
        3. structural rules at +/-inf
        4. one-sided epsilon fallback
    }
    class "Derive" <<utility>> [[calculus.html]] {
        + derive(e, v): _Expression
        memoized (Memo)
    }
    class "Integrate" <<utility>> [[calculus.html]] {
        + integrate(e, v): _Expression
    }
    class "Simplify" <<utility>> [[expressions.html]] {
        + simplify(e): _Expression
        + simplifyFully(e): _Expression
        memoized (Memo)
    }
    class "Expand" <<utility>> [[expressions.html]] {
        + expand(e): _Expression
    }
    class "Normalize" <<utility>> [[equations.html]] {
        + collect(e, v): Option[Vector]
        + normalize(e, v): _Expression
    }
    class "Substitute" <<utility>> [[expressions.html]] {
        + substitute(e, defs): _Expression
    }
    class "Analysis" <<utility>> [[expressions.html]] {
        + dependsOn(e, v): Boolean
    }
    class "Compile" <<utility>> [[calculus.html]] {
        + compile(e, v, env): Option
    }

    class "Syntax" <<object>> [[expressions.html]] {
        simplify() / simplifyFully()
        expand()
        derive(v) / integrate(v)
        dependsOn(v) / substitute(defs)
        compile(v)
    }

    ' Functional nodes call algorithm modules at eval time
    "_Limit"       ..> "Limit"     : evalLimit() at eval
    "_Derivative"  ..> "Derive"    : derive() at eval
    "_Integral"    ..> "Integrate" : integrate() at eval
    "_DefIntegral" ..> "Compile"   : compile() fast path

    ' Syntax sugar delegates to each algorithm module
    "Syntax" ..> "Derive"     : delegates
    "Syntax" ..> "Integrate"  : delegates
    "Syntax" ..> "Simplify"   : delegates
    "Syntax" ..> "Expand"     : delegates
    "Syntax" ..> "Normalize"  : delegates
    "Syntax" ..> "Substitute" : delegates
    "Syntax" ..> "Analysis"   : delegates
    "Syntax" ..> "Compile"    : delegates
}

' ===================================================
' PACKAGE: matrix - matrix domain (imports core + scalar)
' ===================================================
package "matrix" {

    class "_Matrix" <<case>> [[matrix.html]] {
        + rows: Int
        + cols: Int
        + elems: Vector[_Expression]
        __ companion __
        + ofRows(rows*): _Matrix
        + fromValue(v): _Matrix
    }

    interface "_MatrixOperation" <<trait>> [[matrix.html]]

    class "MatSum" <<case>> [[matrix.html]] {
        a : _Expression
        b : _Expression
    }
    class "MatProduct" <<case>> [[matrix.html]] {
        a : _Expression
        b : _Expression
    }
    class "MatScale" <<case>> [[matrix.html]] {
        k : _Expression
        m : _Expression
    }
    class "Transpose" <<case>> [[matrix.html]] {
        m : _Expression
    }
    class "Inverse" <<case>> [[matrix.html]] {
        m : _Expression
        __ inv(A) ; drives 1/A __
        dense: Gauss-Jordan; symbolic: adjugate/det
    }

    class "Determinant" <<case>> [[matrix.html]] {
        m : _Expression
        __ det(A) : 1-based __
        returns SCALAR, not matrix
        dense: LU pivot; symbolic: cofactors
    }

    class "IdentityMatrix" <<case>> [[matrix.html]] {
        n : _Expression
        __ eye(n) __
        n×n matrix with 1s on diagonal
    }

    class "ZeroMatrix" <<case>> [[matrix.html]] {
        nRows : _Expression
        nCols : _Expression
        __ zeros(r, c) / zeros(n) __
        r×c matrix of 0.0
    }

    class "_LUDecomposition" <<case>> [[matrix.html]] {
        m : _Expression
        __ lu(A) → [[L, U, P]] __
        P·A = L·U; partial pivoting
        result: Left(_Matrix(1,3,...))
    }

    class "_QRDecomposition" <<case>> [[matrix.html]] {
        m : _Expression
        __ qr(A) → [[Q, R]] __
        A = Q·R; modified Gram-Schmidt
        result: Left(_Matrix(1,2,...))
    }

    class "_EigenDecomposition" <<case>> [[matrix.html]] {
        m : _Expression
        __ eigen(A) → [[λ₁, λ₂, …, λₙ]] __
        QR iteration + Wilkinson shifts
        real → _Number; complex pair → _Complex
        result: Left(_Matrix(1,n,...))
    }

    class "_EigDecomposition" <<case>> [[matrix.html]] {
        m : _Expression
        __ eig(A) → [[V, D]] __
        spectralDecompose: eigenvectors + D diagonal
        A·V = V·D; complex elems when needed
        result: Left(_Matrix(1,2,...))
    }

    class "_JordanDecomposition" <<case>> [[matrix.html]] {
        m : _Expression
        __ jordan(A) → [[P, J]] __
        A = P·J·P⁻¹ (diagonalizable matrices)
        defective → stays symbolic
        result: Left(_Matrix(1,2,...))
    }

    class "_MatrixIndex" <<case>> [[matrix.html]] {
        matrix : _Expression
        row    : _Expression
        col    : _Expression
        __ at(A, i, j) : 1-based __
        returns scalar element, not matrix
    }

    "_Matrix"          --|> "_Expression"
    "_MatrixOperation" --|> "_Expression"
    "MatSum"           --|> "_MatrixOperation"
    "MatProduct"       --|> "_MatrixOperation"
    "MatScale"         --|> "_MatrixOperation"
    "Transpose"        --|> "_MatrixOperation"
    "Inverse"          --|> "_MatrixOperation"
    "IdentityMatrix"   --|> "_MatrixOperation"
    "ZeroMatrix"       --|> "_MatrixOperation"
    "Determinant"      --|> "_Expression"
    "_MatrixIndex"     --|> "_Expression"
    "_LUDecomposition"    --|> "_Expression"
    "_QRDecomposition"    --|> "_Expression"
    "_EigenDecomposition" --|> "_Expression"
    "_EigDecomposition"   --|> "_Expression"
    "_JordanDecomposition" --|> "_Expression"

    ' Linear containers: derive/simplify/expand/integrate distribute element-wise
    "_Matrix"   ..|> "_ElementWise"
    "MatSum"    ..|> "_ElementWise"
    "Transpose" ..|> "_ElementWise"
    ' Symbolic matrix marker: scalar functions distribute element-wise (exp(A), sin(A), ...)
    "_Matrix"   ..|> "_MatrixShaped"

    "_Matrix"          ..> "_MatrixValue" : collapses to at eval
    "_MatrixOperation" ..> "_MatrixValue" : dense kernels (fast path)
    "_MatrixOperation" ..> "Sum"          : element-wise symbolic combine
    "_MatrixOperation" ..> "Product"      : element-wise symbolic combine
    "_MatrixIndex"     ..> "_MatrixValue" : extracts element at eval
    "Determinant"      ..> "_MatrixValue" : det kernel at eval
    "Inverse"          ..> "_MatrixValue" : inverse kernel at eval
}

' ===================================================
' PACKAGE: transform - Laplace / Fourier / inverse Laplace (imports core + scalar)
' ===================================================
package "transform" {

    class "_Laplace" <<case>> [[calculus.html]] {
        e : _Expression
        t : _Variable
        s : _Variable
    }

    class "_Fourier" <<case>> [[calculus.html]] {
        e : _Expression
        t : _Variable
        w : _Variable
    }

    class "_InverseLaplace" <<case>> [[calculus.html]] {
        f : _Expression
        s : _Variable
        t : _Variable
    }

    class "LaplaceTransform" <<utility>> [[calculus.html]] {
        + laplaceOf(e, t, s): _Expression
        __ rules __
        constants, t^n, exp(ct)
        sin(wt), cos(wt), linearity
        first-shift e^{at}g(t) -> G(s-a)
    }

    class "FourierTransform" <<utility>> [[calculus.html]] {
        + fourierOf(e, t, w): _Expression
        unilateral: L{f} at s = i*w
    }

    class "InverseLaplaceTransform" <<utility>> [[calculus.html]] {
        + inverseLaplaceOf(f, s, t): _Expression
        __ rational N(s)/D(s), deg D <= 2 __
        linearity, b/(s-a) -> b*e^{at}
        partial fractions (distinct roots)
        repeated + complex poles
        (complete the square)
    }

    "_Laplace"        --|> "_Functional"
    "_Fourier"        --|> "_Functional"
    "_InverseLaplace" --|> "_Functional"

    "_Laplace"                ..> "LaplaceTransform"        : laplaceOf() at eval
    "_Fourier"                ..> "FourierTransform"        : fourierOf() at eval
    "_InverseLaplace"         ..> "InverseLaplaceTransform" : inverseLaplaceOf() at eval
    "FourierTransform"        ..> "LaplaceTransform"        : delegates, then s -> i*w
    "FourierTransform"        ..> "Substitute"              : s -> i*w substitution
    "FourierTransform"        ..> "_Complex"                : imaginary unit i
    "InverseLaplaceTransform" ..> "Normalize"              : collect() poly coeffs
    "InverseLaplaceTransform" ..> "Simplify"               : simplifyFully() output
}

' ===================================================
' PACKAGE: equation - equation domain (imports core)
' ===================================================
package "equation" {

    class "compareSides" <<utility>> [[equations.html]] {
        + compareSides(lhs, rhs, env)(wrap): Either
        shared eval logic for _Equation / _EqualityCheck
    }

    class "_Equation" <<case>> [[equations.html]] {
        + lhs : _Expression
        + rhs : _Expression
    }

    class "_EqualityCheck" <<case>> [[equations.html]] {
        + lhs : _Expression
        + rhs : _Expression
    }

    class "_Solve" <<case>> [[equations.html]] {
        + eq : _Expression
        + v  : _Variable
    }

    class "Solve" <<utility>> [[equations.html]] {
        + solve(eq, v, env): List
        __ scalar tiers + __
        matrix unknown: A·X=B → A⁻¹·B
        scalar in matrix eq: element-wise
    }

    class "_SolveSystem" <<case>> [[equations.html]] {
        + equations : _Expression
        + variables : List[_Variable]
    }

    class "SolveSystem" <<utility>> [[equations.html]] {
        + solveSystem(eqs, vars, env): Option[List]
        __ dense path __
        Gaussian elimination (partial pivot)
        __ symbolic path __
        Row reduction with simplifyFully
    }

    "_SolveSystem" --|> "_Expression"
    "_SolveSystem" ..> "SolveSystem" : solve() at eval
    "SolveSystem"  ..> "Normalize"   : collect() coefficient extraction

    "compareSides"    ..> "_Bool"      : produces at eval
    "_Equation"       --|> "_Expression"
    "_Equation"       ..|> "_ElementWise"
    "_Equation"       ..> "compareSides" : delegates eval
    "_Equation"       ..> "_Bool"     : reduces to at eval
    "_EqualityCheck"  --|> "_Expression"
    "_EqualityCheck"  ..|> "_ElementWise"
    "_EqualityCheck"  ..> "compareSides" : delegates eval
    "_EqualityCheck"  ..> "_Bool"     : reduces to at eval
    "_Solve"          --|> "_Expression"
    "_Solve"          ..> "Solve"     : solve() at eval (eq must be _Equation)
    "Solve"     ..> "Normalize" : collect() linear/quadratic tiers
    "Solve"     ..> "Compile"   : numeric fallback
    "Solve"     ..> "_Matrix"   : element-wise matrix-equation decompose
    "Solve"     ..> "_MatrixValue" : inverse kernel (matrix unknown);\nkronecker/vec/unvec (Sylvester tier)
}

' ===================================================
' PACKAGE: parser
' ===================================================
package "parser" {
    class "Parser" <<object>> [[getting-started.html]] {
        + parse(str: String): ParseResult
        + ReservedWords: Set
        __ __
        MaxDepth = 500
        variable ::= [a-zA-Z][a-zA-Z0-9_]*
    }
}

"Parser" ..> "_Expression"    : produces AST nodes
"Parser" ..> "_Matrix"         : matrix row literals
"Parser" ..> "_MatrixOperation": structural + - * dispatch
"Parser" ..> "_MatrixIndex"    : at(A, i, j) element access
"Parser" ..> "Determinant"     : det(A)
"Parser" ..> "Inverse"         : inv(A)
"Parser" ..> "IdentityMatrix"  : eye(n)
"Parser" ..> "ZeroMatrix"      : zeros(r,c)
"Parser" ..> "_LUDecomposition"    : lu(A)
"Parser" ..> "_QRDecomposition"    : qr(A)
"Parser" ..> "_EigenDecomposition" : eigen(A)
"Parser" ..> "_EigDecomposition"   : eig(A)
"Parser" ..> "_JordanDecomposition" : jordan(A)
"Parser" ..> "_Laplace"        : laplace(e, t, s)
"Parser" ..> "_Fourier"        : fourier(e, t, w)
"Parser" ..> "_InverseLaplace" : invlaplace(f, s, t)

' ===================================================
' PACKAGE: cli   (leaf - nothing imports it)
' ===================================================
package "cli" {
    class "Session" [[repl.html]] {
        - precision: Int
        - colorSchemeName: String
        - bindings: Map
        - definitions: Map
        + execute(line: String): String
        + currentColorScheme: String
        + script: String
        + load(text: String): String
        __ companion __
        ReservedConstants: Set = {pi, e}
        + loadFile(session, path): String
        + saveFile(session, path): String
        + step(session, line): Option
    }

    class "ColorScheme" [[repl.html]] {
        command / function / constant
        number / operator / equation
        paren / variable: AttributedStyle
        __ companion __
        Dark / Light / Plain schemes
        All: Map[String, ColorScheme]
        + named(name): ColorScheme
    }

    class "LeonardoHighlighter" [[repl.html]] {
        schemeName: () => String
        + highlight(reader, buffer): AttributedString
    }

    class "repl()" <<main>> [[repl.html]] {
        JLine line editing + history
        syntax highlighting wired
        drives the pure Session.step
    }

    "LeonardoHighlighter" ..> "ColorScheme" : named()

    "repl()" --> "Session" : creates and drives
}

"Session" --> "Parser"      : parses every input line
"Session" --> "Environment" : builds per command
"Session" ..> "Derive"      : derive command
"Session" ..> "Simplify"    : simplify command
"Session" ..> "Expand"      : expand command
"Session" ..> "Substitute"  : resolves definitions

@enduml
